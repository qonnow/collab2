# พอร์ตที่ Backend จะรัน
PORT=5000

# Supabase — ดูได้จาก Supabase Dashboard > Settings > API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# คีย์ลับสำหรับเข้ารหัส AES-256 (ใช้สตริงยาวๆ แบบสุ่ม)
AES_SECRET_KEY=your-aes-secret-key-here

# Origin ที่อนุญาตให้เข้าถึง API (ใส่ * สำหรับอนุญาตทั้งหมด)
CORS_ORIGIN=*

# โหมดการทำงาน (development / production)
NODE_ENV=development
